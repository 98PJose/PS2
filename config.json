{
    "simulation": {
        "Ns": 100000,
        "seed_main": 42,
        "seed_mixture": 123,
        "eps": 1e-10
    },
    "copulas": {
        "clayton": { "theta": 10 },
        "survival_clayton": { "theta": 5 },
        "gaussian": { "rho": -0.7 },
        "student_t": { "rho": -0.7, "nu": 5 },
        "fgm_neg": { "lambda": -0.5 },
        "fgm_zero": { "lambda": 0.0 }
    },
    "marginals": {
        "stock1": { "distribution": "norm", "params": { "loc": 0, "scale": 1 } },
        "stock2": { "distribution": "t", "params": { "df": 6 } }
    },
    "marginals_1d": {
        "stock1": { "distribution": "norm", "params": { "loc": 0, "scale": 1 } },
        "stock2": { "distribution": "norm", "params": { "loc": 0, "scale": 1 } }
    },
    "portfolio": {
        "weights": [0.4, 0.6],
        "var_levels": [0.01, 0.05]
    },
    "mixture": {
        "prob_clayton": 0.6,
        "clayton_theta": 10,
        "surv_clayton_theta": 5
    },
    "estimation": {
        "edf_method": "rank_over_T_plus_1",
        "gaussian_bounds": [-0.9999, 0.9999],
        "t_copula_x0": [0.5, 5.0],
        "t_copula_maxiter": 10000
    },
    "output": {
        "figures_dir": "figures",
        "dpi": 150
    },

    "exercise2": {
        "data_path": "crypto.xlsx",
        "asset_names": ["BTC", "ETH", "ADA"],
        "garch": {
            "mean": 0,
            "maxiter": 5000
        },
        "dcc": {
            "x0_ab": [0.02, 0.95],
            "x0_ab_nu": [0.02, 0.95, 8.0],
            "maxiter": 10000
        }
    },

    "exercise3": {
        "pi": 0.3,
        "rho1": -0.7,
        "rho2": 0.4,
        "q_values": [0.05, 0.25, 0.5, 0.75, 0.95],
        "n_grid": 401,
        "eps": 1e-4
    },

    "exercise4": {
        "N": 100000,
        "strike_grid": { "start": 85, "stop": 115, "step": 1 },
        "gbm": {
            "S0": 100,
            "r": 0.03,
            "mu": 0.08,
            "sigma": 0.2,
            "T": 1
        },
        "part_4_1": { "rho": 0.9 },
        "part_4_2": { "rho": 0.3 },
        "part_4_3": { "rho": 0.3, "nu": 5 },
        "part_4_4": { "theta": 10 },
        "seeds": {
            "part_4_1": 41,
            "part_4_2": 42,
            "part_4_3": 43,
            "part_4_4": 44
        }
    },

    "exercise5": {
        "theta_values": [0.5, 1.5, 2.5],
        "n_obs": 1001,
        "n_sim": 10000,
        "n_rep": 1000,
        "weights": [0.5, 0.5],
        "base_seed": 5001,
        "n_jobs": 1,
        "notes": "Berger (2016) runs n_rep = 10000; we default to 1000 for runtime"
    },

    "exercise6": {
        "Rf_annual":     0.05,
        "mu_annual":     0.10,
        "sigma_annual":  0.20,
        "freq_per_year": 12,
        "zeta_grid":     [-0.010, -0.005, 0.000, 0.005, 0.010],
        "rho_grid":      [-0.25,  0.00,   0.25,  0.50],
        "n_obs":         2000000,
        "base_seed":     6001,
        "sample_path_n": 240,
        "sample_path_rho": 0.25,
        "sample_path_zeta": 0.0,
        "notes": "Reproduces Lo (2007) Table 1: monthly Rf=mu_annual/12, mu=mu_annual/12, Var=sigma_annual^2/12. Two million obs keeps the MC error below 0.1% (annualized)."
    }
}
